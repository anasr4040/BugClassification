# Required — xAI API key used by the LangChain chat models (GROK_API_KEY also accepted).
XAI_API_KEY=your-xai-api-key

# Required — Notion integration secret and target database for bug tickets.
# NOTION_DATABASE_ID accepts either the bare 32-char hex ID or the full
# database URL pasted straight from the browser, e.g.
# https://app.notion.com/p/361092537d94804cb986c7634b316d68?v=...
NOTION_API_KEY=your-notion-integration-secret
NOTION_DATABASE_ID=your-32-char-database-id-or-full-url
# Optional — parent page for first-time database creation via setup_notion_database().
NOTION_PARENT_PAGE_ID=
# When true, print the ticket payload instead of calling the Notion API.
NOTION_DRY_RUN=true

# Optional — LangSmith tracing.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=bug-classifier

# Multi-agent orchestration knobs (defaults shown).
CONFIDENCE_REVIEW_THRESHOLD=0.7
MAX_REVISION_ROUNDS=1
AGENT_TOOL_ROUNDS=3
HITL_EMERGENCY=false
